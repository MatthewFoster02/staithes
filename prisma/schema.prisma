// Prisma schema for the staithes single-property rental platform.
//
// Phase 1 + Phase 2 entities. Messaging / review / extended pricing /
// automated email log entities are still deferred to their respective
// phases per Build_Plan.md.
//
// Field definitions follow foundation_documents/Data_Model_and_Architecture.docx.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum PropertyType {
  house
  flat
  cottage
  cabin
  other
}

enum PropertyStatus {
  active
  paused
  hidden
}

enum CancellationPolicy {
  flexible
  moderate
  strict
}

enum PhotoCategory {
  exterior
  living
  bedroom
  kitchen
  bathroom
  garden
  other
}

enum AmenityCategory {
  essentials
  features
  safety
  accessibility
  outdoor
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum BookingType {
  instant
  request
}

enum PaymentType {
  charge
  refund
  pre_auth
  capture
  damage_charge
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum PricingRuleType {
  seasonal
  day_of_week
  last_minute
  early_bird
  length_discount
}

enum MessageThreadStatus {
  open
  closed
  archived
}

enum MessageSenderType {
  guest
  host
  system
}

enum AutomatedEmailType {
  confirmation
  pre_arrival
  check_in_reminder
  mid_stay
  check_out_reminder
  post_stay_thanks
  review_request
}

enum AutomatedEmailStatus {
  sent
  delivered
  bounced
  failed
}

// ---- Review enum (we use a check constraint via a Postgres int range
// at the app layer rather than a true enum since ratings are decimals).

// ---------- Models ----------

model Property {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String
  slug               String             @unique
  description        String
  shortDescription   String?            @map("short_description")
  propertyType       PropertyType       @map("property_type")
  addressFull        String             @map("address_full")
  addressApprox      String             @map("address_approx")
  latitude           Decimal            @db.Decimal(10, 7)
  longitude          Decimal            @db.Decimal(10, 7)
  maxGuests          Int                @map("max_guests")
  bedrooms           Int
  beds               Int
  bathrooms          Decimal            @db.Decimal(3, 1)
  checkInTime        String             @map("check_in_time")
  checkOutTime       String             @map("check_out_time")
  minStayDefault     Int                @default(1) @map("min_stay_default")
  maxStay            Int?               @map("max_stay")
  baseNightlyRate    Decimal            @map("base_nightly_rate") @db.Decimal(10, 2)
  cleaningFee        Decimal            @default(0) @map("cleaning_fee") @db.Decimal(10, 2)
  extraGuestFee      Decimal            @default(0) @map("extra_guest_fee") @db.Decimal(10, 2)
  baseGuestCount     Int                @map("base_guest_count")
  currency           String             @default("GBP") @db.Char(3)
  houseRules             String?            @map("house_rules")
  cancellationPolicy     CancellationPolicy @default(moderate) @map("cancellation_policy")
  // Ordered list of {minDays, percent} refund tiers. Snapshotted onto
  // each booking so policy changes don't retroactively alter terms.
  // The enum above remains as a label / preset picker for the admin UI.
  cancellationTiers      Json               @default("[]") @map("cancellation_tiers")
  status                 PropertyStatus     @default(active)
  // When true, guests pay immediately on the booking flow. When
  // false, booking creation puts the reservation in request state
  // and waits for host approval before a Stripe session is made.
  instantBookingEnabled  Boolean            @default(true) @map("instant_booking_enabled")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  photos         PropertyPhoto[]
  amenities      PropertyAmenity[]
  bookings       Booking[]
  blockedDates   BlockedDate[]
  pricingRules   PricingRule[]
  messageThreads MessageThread[]
  reviews        Review[]

  @@map("properties")
}

model PropertyPhoto {
  id           String        @id @default(uuid()) @db.Uuid
  propertyId   String        @map("property_id") @db.Uuid
  url          String
  thumbnailUrl String?       @map("thumbnail_url")
  caption      String?
  category     PhotoCategory @default(other)
  altText      String        @map("alt_text")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, sortOrder])
  @@map("property_photos")
}

model Amenity {
  id        String          @id @default(uuid()) @db.Uuid
  name      String          @unique
  icon      String
  category  AmenityCategory
  sortOrder Int             @default(0) @map("sort_order")

  properties PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  propertyId String  @map("property_id") @db.Uuid
  amenityId  String  @map("amenity_id") @db.Uuid
  notes      String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

// Application-level guest profile. The `id` is intended to mirror the
// Supabase `auth.users.id` so a single UUID identifies a user across
// both schemas — credentials live in Supabase Auth, application data
// (bookings, messages, reviews) hangs off this row.
model Guest {
  id                String    @id @db.Uuid
  email             String    @unique
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  phone             String?
  country           String?
  preferredLanguage String?   @map("preferred_language")
  isVerified        Boolean   @default(false) @map("is_verified")
  notesInternal     String?   @map("notes_internal")
  // Explicit GDPR opt-in. Always defaults to false — never pre-checked
  // anywhere in the booking flow. `marketingOptInAt` is the timestamp
  // of the last positive consent for audit purposes.
  marketingOptIn    Boolean   @default(false) @map("marketing_opt_in")
  marketingOptInAt  DateTime? @map("marketing_opt_in_at")
  // Random per-guest token used for one-click unsubscribe links in
  // marketing emails. Lazy-allocated when a guest first opts in.
  unsubscribeToken  String?   @unique @map("unsubscribe_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastLoginAt       DateTime? @map("last_login_at")

  bookings       Booking[]
  messageThreads MessageThread[]
  messagesSent   Message[]
  reviews        Review[]

  @@map("guests")
}

// Audit log of marketing newsletters sent. Lets the host see what
// went out, to how many people, and what the failure rate was. We
// don't log per-recipient deliveries — Resend keeps that — only the
// aggregate counts.
model NewsletterSend {
  id              String   @id @default(uuid()) @db.Uuid
  subject         String
  bodyMarkdown    String   @map("body_markdown")
  sentAt          DateTime @default(now()) @map("sent_at")
  recipientCount  Int      @map("recipient_count")
  successCount    Int      @map("success_count")
  failureCount    Int      @map("failure_count")

  @@map("newsletter_sends")
}

// The central transactional entity. Snapshots price + cancellation
// policy at booking time so later changes never retroactively alter
// existing reservations.
model Booking {
  id                       String        @id @default(uuid()) @db.Uuid
  propertyId               String        @map("property_id") @db.Uuid
  guestId                  String        @map("guest_id") @db.Uuid
  checkIn                  DateTime      @map("check_in") @db.Date
  checkOut                 DateTime      @map("check_out") @db.Date
  numGuestsAdults          Int           @map("num_guests_adults")
  numGuestsChildren        Int           @default(0) @map("num_guests_children")
  status                   BookingStatus @default(pending)
  bookingType              BookingType   @default(instant) @map("booking_type")
  totalPrice               Decimal       @map("total_price") @db.Decimal(10, 2)
  currency                 String        @db.Char(3)
  cancellationPolicySnapshot Json        @map("cancellation_policy_snapshot")
  guestMessage             String?       @map("guest_message")
  specialRequests          String?       @map("special_requests")
  checkInInstructionsSent  Boolean       @default(false) @map("check_in_instructions_sent")
  cancellationReason       String?       @map("cancellation_reason")
  createdAt                DateTime      @default(now()) @map("created_at")
  confirmedAt              DateTime?     @map("confirmed_at")
  cancelledAt              DateTime?     @map("cancelled_at")
  completedAt              DateTime?     @map("completed_at")
  // Set when the host approves a request-to-book booking. Remains
  // null until approval; also null for instant bookings (they skip
  // this state and go straight to confirmed via the Stripe webhook).
  approvedAt               DateTime?     @map("approved_at")

  property        Property              @relation(fields: [propertyId], references: [id])
  guest           Guest                 @relation(fields: [guestId], references: [id])
  priceSnapshot   BookingPriceSnapshot?
  payments        Payment[]
  messageThread   MessageThread?
  automatedEmails AutomatedEmailLog[]
  review          Review?

  @@index([propertyId, checkIn, checkOut, status])
  @@index([guestId])
  @@map("bookings")
}

// The itemised price breakdown frozen at booking time. One-to-one
// with Booking. Stored separately so receipts and audit trails are
// clean and the Booking row stays focused on lifecycle state.
model BookingPriceSnapshot {
  id                    String   @id @default(uuid()) @db.Uuid
  bookingId             String   @unique @map("booking_id") @db.Uuid
  nightlyRates          Json     @map("nightly_rates") // [{ date: "YYYY-MM-DD", rate: 145.00 }]
  numNights             Int      @map("num_nights")
  subtotalAccommodation Decimal  @map("subtotal_accommodation") @db.Decimal(10, 2)
  cleaningFee           Decimal  @default(0) @map("cleaning_fee") @db.Decimal(10, 2)
  extraGuestFeeTotal    Decimal  @default(0) @map("extra_guest_fee_total") @db.Decimal(10, 2)
  discountAmount        Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountDescription   String?  @map("discount_description")
  serviceFee            Decimal  @default(0) @map("service_fee") @db.Decimal(10, 2)
  taxAmount             Decimal  @default(0) @map("tax_amount") @db.Decimal(10, 2)
  taxDescription        String?  @map("tax_description")
  total                 Decimal  @db.Decimal(10, 2)
  currency              String   @db.Char(3)
  createdAt             DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_price_snapshots")
}

// Individual financial transactions against a booking. A booking may
// have many payments over its lifetime (initial charge, refunds,
// damage charges, etc.).
model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  bookingId            String        @map("booking_id") @db.Uuid
  type                 PaymentType
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @db.Char(3)
  status               PaymentStatus @default(pending)
  gateway              String
  gatewayTransactionId String?       @map("gateway_transaction_id")
  gatewayResponse      Json?         @map("gateway_response")
  cardLastFour         String?       @map("card_last_four")
  cardBrand            String?       @map("card_brand")
  refundReason         String?       @map("refund_reason")
  createdAt            DateTime      @default(now()) @map("created_at")
  completedAt          DateTime?     @map("completed_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("payments")
}

// Date ranges manually blocked by the host. Treated as unavailable
// in the calendar alongside confirmed/pending bookings.
model BlockedDate {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  dateStart  DateTime @map("date_start") @db.Date
  dateEnd    DateTime @map("date_end") @db.Date
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, dateStart, dateEnd])
  @@map("blocked_dates")
}

// Overrides to the base nightly rate for specific date ranges, days
// of the week, or stay lengths. Rules are evaluated in priority order;
// the most specific matching rule wins. Phase 2 only writes the
// schema; the full pricing engine that consumes these rules lands in
// Phase 7.
model PricingRule {
  id                   String          @id @default(uuid()) @db.Uuid
  propertyId           String          @map("property_id") @db.Uuid
  name                 String
  type                 PricingRuleType
  dateStart            DateTime?       @map("date_start") @db.Date
  dateEnd              DateTime?       @map("date_end") @db.Date
  daysOfWeek           Int[]           @default([]) @map("days_of_week")
  nightlyRate          Decimal?        @map("nightly_rate") @db.Decimal(10, 2)
  rateMultiplier       Decimal?        @map("rate_multiplier") @db.Decimal(5, 3)
  minStay              Int?            @map("min_stay")
  minNightsForDiscount Int?            @map("min_nights_for_discount")
  discountPercent      Decimal?        @map("discount_percent") @db.Decimal(5, 2)
  daysBeforeCheckin    Int?            @map("days_before_checkin")
  daysAdvanceBooking   Int?            @map("days_advance_booking")
  priority             Int             @default(0)
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, isActive, priority])
  @@map("pricing_rules")
}

// Conversation container between a guest and the host. Linked to a
// booking when one exists, but pre-booking enquiries create threads
// without a booking_id and get linked later if the enquiry converts.
// `bookingId` is unique-when-not-null so each booking gets at most
// one thread; multiple pre-booking enquiry threads from the same
// guest are allowed (each NULL is distinct in Postgres UNIQUE).
model MessageThread {
  id         String              @id @default(uuid()) @db.Uuid
  propertyId String              @map("property_id") @db.Uuid
  guestId    String              @map("guest_id") @db.Uuid
  bookingId  String?             @unique @map("booking_id") @db.Uuid
  subject    String?
  status     MessageThreadStatus @default(open)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guest    Guest     @relation(fields: [guestId], references: [id])
  booking  Booking?  @relation(fields: [bookingId], references: [id])
  messages Message[]

  @@index([propertyId, status, updatedAt])
  @@index([guestId, updatedAt])
  @@map("message_threads")
}

// A single message inside a thread. `senderType` distinguishes
// guest, host, and system messages. `senderId` references the Guest
// row when senderType=guest, otherwise null (host messages don't
// have a guest id, and there's only ever one host per single-property
// site so we don't model the host as a row).
//
// `isRead` is interpreted as "read by the recipient" — i.e. for a
// guest message it means the host has seen it; for a host message
// it means the guest has seen it. The service layer flips it when
// the recipient opens the thread.
model Message {
  id         String            @id @default(uuid()) @db.Uuid
  threadId   String            @map("thread_id") @db.Uuid
  senderType MessageSenderType @map("sender_type")
  senderId   String?           @map("sender_id") @db.Uuid
  content    String
  isRead     Boolean           @default(false) @map("is_read")
  createdAt  DateTime          @default(now()) @map("created_at")

  thread       MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderGuest  Guest?        @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@map("messages")
}

// Guest review of a completed stay. One per booking enforced via the
// `bookingId` unique constraint. Sub-ratings (1.0–5.0 with 0.5 step)
// give the host actionable per-dimension feedback; the overall rating
// is what shows on the property page average. The host can publish
// or unpublish (moderation) and add a public response.
//
// `propertyId` is denormalised onto the row so the public reviews
// query on the property page is a single index lookup without
// joining through Booking — important because the property page is
// the highest-traffic surface in the app.
model Review {
  id                  String    @id @default(uuid()) @db.Uuid
  bookingId           String    @unique @map("booking_id") @db.Uuid
  guestId             String    @map("guest_id") @db.Uuid
  propertyId          String    @map("property_id") @db.Uuid
  ratingOverall       Decimal   @map("rating_overall") @db.Decimal(2, 1)
  ratingCleanliness   Decimal   @map("rating_cleanliness") @db.Decimal(2, 1)
  ratingAccuracy      Decimal   @map("rating_accuracy") @db.Decimal(2, 1)
  ratingCommunication Decimal   @map("rating_communication") @db.Decimal(2, 1)
  ratingLocation      Decimal   @map("rating_location") @db.Decimal(2, 1)
  ratingValue         Decimal   @map("rating_value") @db.Decimal(2, 1)
  reviewText          String?   @map("review_text")
  hostResponse        String?   @map("host_response")
  hostRespondedAt     DateTime? @map("host_responded_at")
  isPublished         Boolean   @default(true) @map("is_published")
  createdAt           DateTime  @default(now()) @map("created_at")

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guest    Guest    @relation(fields: [guestId], references: [id])
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, isPublished, createdAt])
  @@map("reviews")
}

// Daily idempotency key for the host summary email. The unique
// constraint on `date` ensures the cron only ever sends one summary
// per UTC day no matter how many times it fires (Vercel Cron is
// at-least-once delivery). Rows accumulate slowly — one per day —
// and can be pruned once a year if needed.
model HostDailySummaryLog {
  id     String   @id @default(uuid()) @db.Uuid
  date   DateTime @unique @db.Date
  sentAt DateTime @default(now()) @map("sent_at")

  @@map("host_daily_summary_logs")
}

// Audit log of automated emails sent for a booking. The unique
// constraint on (booking_id, email_type) is the *idempotency* key —
// the scheduler tries to insert a row before sending; a unique
// violation means another invocation has already claimed the send.
// On Resend failure the row is deleted so the next cron tick retries.
model AutomatedEmailLog {
  id             String               @id @default(uuid()) @db.Uuid
  bookingId      String               @map("booking_id") @db.Uuid
  emailType      AutomatedEmailType   @map("email_type")
  recipientEmail String               @map("recipient_email")
  subject        String
  status         AutomatedEmailStatus @default(sent)
  sentAt         DateTime             @default(now()) @map("sent_at")
  deliveredAt    DateTime?            @map("delivered_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, emailType])
  @@index([sentAt])
  @@map("automated_email_logs")
}

// Idempotency log for inbound Stripe webhooks. The Stripe event id
// is the primary key, so re-delivery of the same event collides with
// a unique-violation and the handler safely no-ops. Rows can be
// pruned periodically — keeping a few months is plenty for debugging.
model WebhookEvent {
  id          String   @id
  source      String   @default("stripe")
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([source, type, processedAt])
  @@map("webhook_events")
}

// Singleton: exactly one row, enforced via a single fixed id at insert time.
model SiteConfiguration {
  id              String   @id @default(uuid()) @db.Uuid
  siteName        String   @map("site_name")
  tagline         String?
  logoUrl         String?  @map("logo_url")
  primaryColour   String?  @map("primary_colour")
  accentColour    String?  @map("accent_colour")
  contactEmail    String   @map("contact_email")
  contactPhone    String?  @map("contact_phone")
  senderEmail     String?  @map("sender_email")
  senderName      String?  @map("sender_name")
  seoTitle        String?  @map("seo_title")
  seoDescription  String?  @map("seo_description")
  ogImageUrl      String?  @map("og_image_url")
  analyticsId     String?  @map("analytics_id")
  timezone        String   @default("Europe/London")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_configuration")
}
