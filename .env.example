# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
#
# Local dev runs Supabase via the CLI (`supabase start`) on bumped ports
# (544xx instead of 543xx). Get the current values from `supabase status -o env`.
# For production, use the values from your hosted Supabase project dashboard.

# --- Database (Supabase Postgres via Prisma) ---
# Local: postgresql://postgres:postgres@127.0.0.1:54422/postgres
# Prod:  pooled connection string from Supabase dashboard (port 6543, ?pgbouncer=true)
DATABASE_URL=
# Local: same as DATABASE_URL
# Prod:  direct (non-pooled) connection used by Prisma migrations (port 5432)
DIRECT_URL=

# --- Supabase ---
# Local: http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- MapTiler ---
NEXT_PUBLIC_MAPTILER_API_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
